{
  "name": "system-brain-mcp",
  "version": "0.1.1",
  "description": "MCP server that gives your coding agent a queryable, honest view of your own system \u2014 where code deploys, what's fabricated, what's open, whether the learning loop closes",
  "license": "MIT",
  "main": "server.js",
  "bin": {
    "system-brain-mcp": "server.js",
    "system-brain-init": "bin/init.js"
  },
  "files": [
    "server.js",
    "src/",
    "config/",
    "bin/"
  ],
  "scripts": {
    "start": "node server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "deploy",
    "introspection",
    "code-audit"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QEbellavita/system-brain-mcp.git"
  },
  "homepage": "https://github.com/QEbellavita/system-brain-mcp#readme",
  "bugs": {
    "url": "https://github.com/QEbellavita/system-brain-mcp/issues"
  },
  "author": "Belinda Switzer (https://github.com/QEbellavita)"
}
